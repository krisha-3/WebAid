{
  "manifest_version": 3,
  "name": "Accessibility Toolkit",
  "version": "1.1.0",
  "description": "Enhance web readability with font scaling, spacing adjustments, dark mode, reader mode, and page notes.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["content.css"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage", "activeTab", "contextMenus"]
}
